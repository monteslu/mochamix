{
  "name": "@dj/desktop",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "The dj-app Electron app.",
  "main": "dist-main/main.js",
  "scripts": {
    "build:renderer": "vite build",
    "build:worklet": "vite build --config vite.worklet.config.ts",
    "build:main": "node scripts/build-main.mjs",
    "typecheck:main": "tsc -p tsconfig.main.json --noEmit",
    "build": "npm run build:renderer && npm run build:worklet && npm run build:main",
    "postinstall": "node scripts/ensure-electron.js",
    "dev": "npm run build && node scripts/run-electron.mjs --dev --no-sandbox",
    "start": "npm run build && node scripts/run-electron.mjs --no-sandbox",
    "dev:web": "vite --config vite.browser.config.ts",
    "build:web": "vite build --config vite.browser.config.ts",
    "e2e": "playwright test"
  },
  "dependencies": {
    "@dj/audio-engine": "*",
    "@dj/codec": "*",
    "@dj/control-bus": "*",
    "@dj/db": "*",
    "@dj/waveform": "*",
    "music-metadata": "^11.13.0",
    "node-sqlite3-wasm": "^0.8.58",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/pngjs": "^6.0.5",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.3",
    "@webgpu/types": "^0.1.52",
    "electron": "^42.5.0",
    "pngjs": "^7.0.0",
    "vite": "^8.1.0"
  }
}
