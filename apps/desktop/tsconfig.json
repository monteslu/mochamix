{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist-tsc",
    "jsx": "react-jsx",
    "lib": ["ES2023", "DOM", "DOM.Iterable", "WebWorker"],
    "types": ["@webgpu/types", "vite/client"],
    "composite": false,
