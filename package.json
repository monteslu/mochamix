{
  "name": "mochamix",
  "version": "0.0.0",
  "private": true,
  "description": "A Mixxx-class DJ application built in Electron. Proof you can build just about anything with web tech.",
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build:packages": "npm run build --workspaces --if-present",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "typecheck": "tsc --build",
    "dev": "npm run dev --workspace apps/desktop",
    "pack:publish": "npm run pack:publish --workspace apps/desktop",
    "release": "npm run pack:publish --workspace apps/desktop && npm publish ./apps/desktop/publish"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.0.1",
    "eslint": "^10.5.0",
    "prettier": "^3.4.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vitest": "^4.1.9"
  }
}
